# Указываем базовый образ с Node.js (версия 20-alpine легкая и стабильная)
FROM node:20-alpine

# Создаем рабочую папку внутри контейнера
WORKDIR /app

# Копируем все файлы из нашего проекта в контейнер
COPY . .

# Команда, которая выполнится при старте контейнера (запуск твоего app.js)
CMD ["node", "test2.js"]